#!/usr/bin/env node
// graphify-hook-start
// Auto-rebuilds the knowledge graph after each commit (code files only, no LLM needed).
// Installed by: graphify hook install

const { spawnSync, spawn } = require('node:child_process')
const { existsSync } = require('node:fs')
const { join } = require('node:path')
const { homedir } = require('node:os')

// Skip during rebase/merge/cherry-pick
const gitDir = spawnSync('git', ['rev-parse', '--git-dir'], { encoding: 'utf8', windowsHide: true }).stdout?.trim()
if (gitDir) {
  if (existsSync(join(gitDir, 'rebase-merge'))) process.exit(0)
  if (existsSync(join(gitDir, 'rebase-apply'))) process.exit(0)
  if (existsSync(join(gitDir, 'MERGE_HEAD'))) process.exit(0)
  if (existsSync(join(gitDir, 'CHERRY_PICK_HEAD'))) process.exit(0)
}

if (process.env.GRAPHIFY_SKIP_HOOK === '1') process.exit(0)

// Only run if graphify-out/ exists (graph has been built before)
if (!existsSync('graphify-out')) process.exit(0)

// Skip when only graphify-out/ artifacts changed (avoids rebuild loop)
let changed = spawnSync('git', ['diff', '--name-only', 'HEAD~1', 'HEAD'], { encoding: 'utf8', windowsHide: true }).stdout?.trim()
if (!changed) changed = spawnSync('git', ['diff', '--name-only', 'HEAD'], { encoding: 'utf8', windowsHide: true }).stdout?.trim()
if (!changed) process.exit(0)
const nonGraphFiles = changed.split('\n').filter(f => f && !f.startsWith('graphify-out/'))
if (nonGraphFiles.length === 0) process.exit(0)

// Run graphify update in background — don't block git
// Prepend $HOME/.local/bin so uv-installed graphify is found in non-interactive shells
const uvBin = join(homedir(), '.local', 'bin')
const child = spawn('graphify', ['update', '.'], {
  detached: true,
  stdio: 'ignore',
  windowsHide: true,
  env: { ...process.env, PYTHONHASHSEED: '0', PATH: `${uvBin}${process.platform === 'win32' ? ';' : ':'}${process.env.PATH || ''}` },
})
child.on('error', () => {}) // silently skip if graphify not on PATH
child.unref()
// graphify-hook-end
