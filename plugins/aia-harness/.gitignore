node_modules/
*.local.json
*.local.md
.claude/*.local.md
.claude/*.local.json
.DS_Store
*.log
coverage/
.tsbuildinfo

# Root .mcp.json is plugin-level — committing it would impose its MCP servers on
# every project that enables aia-harness. MCPs are suggested per-target on apply.
# Keep a local copy for dogfooding, but never ship it.
/.mcp.json

# graphify — local artifact, not tracked
graphify-out/

# SDD progress ledgers and review packages — local only
.superpowers/

# Python bytecode — never commit into vendored templates (e.g. ag-kit scripts)
__pycache__/
*.pyc
