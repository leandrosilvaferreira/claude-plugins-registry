{
  "name": "aia-harness",
  "version": "0.3.0",
  "description": "Scan a project and scaffold a complete Claude Code harness: hooks, skills, agents, rules, settings, strategic MCPs, worktree config and per-domain CLAUDE.md. Diagnose, approve, apply.",
  "author": {
    "name": "Leandro Silva Ferreira",
    "email": "leandrosilvaferreira@gmail.com"
  },
  "repository": "https://github.com/leandrosilvaferreira/aia_harness",
  "homepage": "https://github.com/leandrosilvaferreira/aia_harness",
  "license": "MIT",
  "keywords": [
    "harness",
    "scaffold",
    "bootstrap",
    "automation",
    "stack-detection",
    "claude-md",
    "hooks",
    "worktrees",
    "mcp"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/suggest-harness.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
